# ZenithOKR Backend Environment Variables Example
# Duplicate this file to .env and configure the variables accordingly.

# FastAPI Secret Key for JWT signature. Generate a secure random string (e.g. openssl rand -hex 32)
SECRET_KEY=replace_with_your_jwt_signing_secret_key_32_chars_or_more

# Database connection URL. SQLite default is sqlite:///./zenithokr.db
DATABASE_URL=sqlite:///./zenithokr.db

# CORS Allowed Origins (Comma-separated list of origins permitted to request backend resources)
# In production, set to your Vercel deployment URL: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Microsoft Azure Entra ID / SSO Configurations (Required for Azure AD integration)
AZURE_TENANT_ID=your_azure_tenant_id_guid
AZURE_ADMIN_GROUP_ID=your_azure_ad_admin_group_object_id_guid
AZURE_MANAGER_GROUP_ID=your_azure_ad_manager_group_object_id_guid
