# ZenithOKR Frontend Environment Variables Example
# Duplicate this file to .env and configure the variables accordingly.

# Backend API Endpoint Base URL (No trailing slash)
# For local dev: http://localhost:8000
# For production: https://your-backend-app.onrender.com
VITE_API_URL=http://localhost:8000

# Microsoft Azure Entra ID App Registration Client ID (Application ID)
VITE_AZURE_CLIENT_ID=your_azure_ad_client_id_guid

# Microsoft Azure Entra ID Tenant ID (Directory ID)
VITE_AZURE_TENANT_ID=your_azure_ad_tenant_id_guid
